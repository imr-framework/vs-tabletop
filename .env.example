# Postgres (docker-compose)
POSTGRES_USER=vst
POSTGRES_PASSWORD=vstpass
POSTGRES_DB=vstabletop
# Host port (container still uses 5432). Use 5433 if something already listens on 5432.
POSTGRES_PORT=5433

# App
APP_PORT=8080
SECRET_KEY=
WTF_CSRF_SECRET_KEY=
SESSION_COOKIE_SECURE=
SESSION_COOKIE_SAMESITE=

# DB bootstrap inside web container (set to 1 only for local/dev convenience)
AUTO_DB_INIT=0
# 1 = also seed default admin user (dev only)
INIT_ADMIN=0

# Clerk
CLERK_ENABLED=
CLERK_PUBLISHABLE_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_FRONTEND_API=
